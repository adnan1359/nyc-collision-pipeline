# ─── Databricks ──────────────────────────────────────────────────────────────
# Workspace URL — no trailing slash.
DATABRICKS_HOST=https://adb-<workspace-id>.<region>.azuredatabricks.net

# Personal Access Token (PAT) or OAuth M2M token for a service principal.
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# HTTP path for the Databricks Serverless SQL Warehouse.
# Used by dbt AND by run_sql.py (which parses the warehouse ID from the end of it).
# Find it: SQL Warehouses → your warehouse → Connection details → HTTP path
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxx

# ─── Observability ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
